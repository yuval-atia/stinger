{
  "name": "stinger",
  "private": true,
  "version": "1.10.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-sitemap.js && node scripts/prerender-meta.js && cp dist/index.html dist/404.html",
